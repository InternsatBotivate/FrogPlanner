# =====================================================================
# FrogPlanner (web) — environment variables
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# =====================================================================

# ── Client (browser) config — VITE_ vars are PUBLIC (inlined into the
#    bundle). Only publishable/anon keys and public identifiers belong here.
# ---------------------------------------------------------------------

# Supabase — from https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-publishable-anon-key>

# Google Calendar OAuth 2.0 Web Client ID — from console.cloud.google.com
VITE_GOOGLE_CLIENT_ID=<your-web-oauth-client-id>.apps.googleusercontent.com

# AI Assistant proxy URL (optional). The web app calls the same-origin
# /api/ai-chat by default, so leave this UNSET for normal deployments.
# Only set it to point at a proxy hosted on a different origin.
# VITE_AI_PROXY_URL=https://<other-host>/api/ai-chat


# ── Server-only secrets — used by the serverless functions in api/.
#    These are NOT prefixed with VITE_ and are NEVER shipped to the client.
#    Set them in the Vercel dashboard (Project → Environment Variables),
#    not just in local files.
# ---------------------------------------------------------------------

# Cerebras — powers the AI Assistant proxy (api/ai-chat.js). Keep secret.
CEREBRAS_API_KEY=<your-cerebras-api-key>
# Optional overrides (defaults shown):
# CEREBRAS_MODEL=gpt-oss-120b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# Supabase service-role key — used by api/ai-chat.js (session validation)
# and api/create-recurring-tasks.js. Full-access secret; keep server-side.
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Optional shared secret guarding the recurring-tasks cron endpoint.
# CRON_SECRET=<random-secret>
